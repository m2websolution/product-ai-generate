{%- liquid
  assign schema_meta = nil
  assign faq_meta = nil

  if product
    assign schema_meta = product.metafields.content_ai_geo.schema_json
    assign faq_meta = product.metafields.content_ai_geo.faq_json
  elsif article
    assign schema_meta = article.metafields.content_ai_geo.schema_json
    assign faq_meta = article.metafields.content_ai_geo.faq_json
  elsif page
    assign schema_meta = page.metafields.content_ai_geo.schema_json
  endif
-%}

{%- if schema_meta != blank -%}
<script type="application/ld+json">
  {{- schema_meta.value | json -}}
</script>
{%- endif -%}

{%- if faq_meta != blank -%}
<script type="application/ld+json">
  {{- faq_meta.value | json -}}
</script>
{%- if product -%}
<style>
  .cai-faq {
    margin: 40px 0;
    font-family: inherit;
  }
  .cai-faq__title {
    text-align: center;
    font-size: 1.35rem;
    font-weight: 400;
    margin: 0 0 20px;
    line-height: 1.3;
    color: inherit;
  }
  .cai-faq__title strong {
    font-weight: 700;
  }
  .cai-faq__item {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
    margin-bottom: 10px;
    overflow: hidden;
  }
  .cai-faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    font-size: 0.95rem;
    color: #111111;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  .cai-faq__summary::-webkit-details-marker { display: none; }
  .cai-faq__summary::marker { display: none; }
  .cai-faq__chevron {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid #c8c8c8;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease, border-color 0.2s ease;
    color: #555555;
  }
  .cai-faq__item[open] .cai-faq__chevron {
    transform: rotate(180deg);
    border-color: #999999;
  }
  .cai-faq__answer {
    padding: 0 20px 16px;
    font-size: 0.9rem;
    color: #555555;
    line-height: 1.65;
  }
</style>
<script>
  (function () {
    var faqData = {{ faq_meta.value | json }};

    function sanitize(value) {
      return String(value || "").replace(/\s+/g, " ").trim();
    }

    function getItems(data) {
      var parsed = data;
      if (typeof parsed === "string") {
        try { parsed = JSON.parse(parsed); } catch (e) { parsed = null; }
      }
      var entities = parsed && Array.isArray(parsed.mainEntity) ? parsed.mainEntity : [];
      return entities.map(function (item) {
        return {
          question: sanitize(item && item.name),
          answer: sanitize(item && item.acceptedAnswer && item.acceptedAnswer.text)
        };
      }).filter(function (item) {
        return item.question && item.answer;
      });
    }

    var CHEVRON_SVG = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>';

    function appendFaqAccordion() {
      if (document.querySelector("[data-cai-faq]")) return;
      var items = getItems(faqData);
      if (!items.length) return;

      var section = document.createElement("section");
      section.className = "cai-faq";
      section.setAttribute("data-cai-faq", "true");

      var heading = document.createElement("h2");
      heading.className = "cai-faq__title";
      heading.innerHTML = "Frequently Asked <strong>Questions</strong>";
      section.appendChild(heading);

      items.forEach(function (item) {
        var details = document.createElement("details");
        details.className = "cai-faq__item";

        var summary = document.createElement("summary");
        summary.className = "cai-faq__summary";

        var questionSpan = document.createElement("span");
        questionSpan.textContent = item.question;

        var chevron = document.createElement("span");
        chevron.className = "cai-faq__chevron";
        chevron.setAttribute("aria-hidden", "true");
        chevron.innerHTML = CHEVRON_SVG;

        summary.appendChild(questionSpan);
        summary.appendChild(chevron);

        var answer = document.createElement("div");
        answer.className = "cai-faq__answer";
        answer.textContent = item.answer;

        details.appendChild(summary);
        details.appendChild(answer);
        section.appendChild(details);
      });

      var target =
        document.querySelector("product-info") ||
        document.querySelector(".product__info-container") ||
        document.querySelector(".product__description") ||
        document.querySelector("[data-product-description]");
      if (target) {
        target.insertAdjacentElement("afterend", section);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", appendFaqAccordion);
    } else {
      appendFaqAccordion();
    }
  })();
</script>
{%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "AI Visibility",
  "target": "head",
  "settings": []
}
{% endschema %}
